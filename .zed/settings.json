{
  "file_scan_exclusions": [
    "**/.git",
    "**/.venv",
    "**/__pycache__",
    "**/.pytest_cache",
    "**/.ruff_cache",
  ],
  "languages": {
    "Python": {
      "language_servers": ["ty", "!basedpyright"],
      "format_on_save": "off",
      "code_actions_on_format": {
        "source.organizeImports.ruff": true,
        "source.fixAll.ruff": true,
      },
    },
  },
}
